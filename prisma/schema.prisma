generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Event {
  id              String   @id @default(uuid())
  type            String
  payload         Json
  idempotencyKey  String?  @unique
  createdAt       DateTime @default(now())

  deliveries WebhookDelivery[]

  @@index([type])
  @@index([createdAt])
  @@index([idempotencyKey])
  @@map("events")
}

model Webhook {
  id              String   @id @default(uuid())
  url             String
  secret          String
  eventTypes      String[]
  isActive        Boolean  @default(true)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  deliveries      WebhookDelivery[]

  @@index([isActive])
  @@map("webhooks")
}

model WebhookDelivery {
  id              String   @id @default(uuid())
  eventId         String
  webhookId       String
  status          DeliveryStatus @default(PENDING)
  attempts        Int      @default(0)
  lastAttemptAt   DateTime?
  nextRetryAt     DateTime?
  responseStatus  Int?
  responseBody    String?
  errorMessage    String?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  event           Event    @relation(fields: [eventId], references: [id], onDelete: Cascade)
  webhook         Webhook  @relation(fields: [webhookId], references: [id], onDelete: Cascade)

  @@index([eventId])
  @@index([webhookId])
  @@index([status])
  @@index([nextRetryAt])
  @@map("webhook_deliveries")
}

enum DeliveryStatus {
  PENDING
  PROCESSING
  SUCCESS
  FAILED
  DEAD_LETTER
}

model AuditLog {
  id           String   @id @default(uuid())
  action       String
  entityType   String
  entityId     String
  userId       String?
  ipAddress    String?
  userAgent    String?
  metadata     Json?
  createdAt    DateTime @default(now())

  @@index([entityType, entityId])
  @@index([action])
  @@index([createdAt])
  @@map("audit_logs")
}

model IdempotencyCache {
  key          String   @id
  response     Json
  statusCode   Int
  expiresAt    DateTime
  createdAt    DateTime @default(now())

  @@index([expiresAt])
  @@map("idempotency_cache")
}
